{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Apna Browser",
  "version": "0.1.0",
  "identifier": "com.apnipathshala.apna-browser",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Apna Browser",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
